# ─── App ────────────────────────────────────────
APP_NAME=JyotishAI
APP_ENV=development          # development | staging | production
APP_VERSION=1.0.0
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Security ────────────────────────────────────
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# ─── Firebase (Firestore as primary DB) ──────────
FIREBASE_PROJECT_ID=jyotish-ai
FIREBASE_CREDENTIALS_JSON=./firebase-credentials.json

# ─── Astrology APIs ──────────────────────────────
PROKERALA_CLIENT_ID=your_prokerala_client_id
PROKERALA_CLIENT_SECRET=your_prokerala_client_secret
PROKERALA_BASE_URL=https://api.prokerala.com/v2/astrology

ASTROAPI_KEY=your_astroapi_key
ASTROAPI_BASE_URL=https://json.astrologyapi.com/v1

# ─── AI (for AI chat feature) ────────────────────
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini

# ─── Payments ────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Rate Limiting ───────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AI_PER_MINUTE=10
